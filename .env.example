# Kubecost Integration Configuration
# Copy this file to .env and fill in your credentials

# ============================================================================
# AUTHENTICATION (Required)
# ============================================================================

# Apptio OpenToken (from browser cookies: shell-opentoken)
# Get from: Browser DevTools → Application → Cookies → shell-opentoken
APPTIO_OPENTOKEN=your-opentoken-here

# Apptio Environment ID (from browser cookies: envid)
# Get from: Browser DevTools → Application → Cookies → envid
APPTIO_ENVIRONMENT_ID=your-environment-id-here

# ============================================================================
# OPTIONAL CONFIGURATION
# ============================================================================

# Cloudability API URL (default: https://api.cloudability.com)
# CLOUDABILITY_API_URL=https://api.cloudability.com

# ============================================================================
# HOW TO GET CREDENTIALS
# ============================================================================
# 1. Open Cloudability in your browser: https://app.apptio.com/cloudability
# 2. Open Developer Tools (F12)
# 3. Go to Application tab → Cookies → https://app.apptio.com
# 4. Find and copy:
#    - shell-opentoken (long hexadecimal string)
#    - envid (UUID format)
# 5. Paste values above
#
# Note: OpenToken expires when your browser session ends